Cell[TextData[{
 "Furthermore, students will ",
 StyleBox["computationally",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " demonstrate algebraic properties of convolutions including:\n\n1. \
Commutativity: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "\[CircleTimes]", "g"}], "=", 
   RowBox[{"g", "\[CircleTimes]", "f"}]}]],ExpressionUUID->
  "5e2b5193-2379-4bac-9611-c5dd58728671"],
 "\n2. Associativity: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"g", "\[CircleTimes]", "h"}], ")"}]}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"f", "\[CircleTimes]", "g"}], ")"}], "\[CircleTimes]", "h"}]}]],
  ExpressionUUID->"f7a0a259-0776-4a95-b8e7-01a770686b41"],
 "\n3. Distributivity: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"g", "+", "h"}], ")"}]}], "=", 
   RowBox[{
    RowBox[{"f", "\[CircleTimes]", "g"}], "+", 
    RowBox[{"f", "\[CircleTimes]", "h"}]}]}]],ExpressionUUID->
  "4517c422-075f-4319-add3-ae8fa02820ff"],
 "\n4. Multiplicative identity: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "\[CircleTimes]", "\[Delta]"}], "=", "f"}]],ExpressionUUID->
  "726e1781-a1f8-4c85-93cd-5b6ba9c0fd6e"],
 "\n\nThese can be demonstrated by calculating the RMS error between the left \
and right hand side of each equation ",
 StyleBox["EXCEPT",
  FontWeight->"Bold"],
 " for property 4. Students will demonstrate this property approximately \
through an animation."
}], "Text",
 CellChangeTimes->{{3.755284626322426*^9, 3.755284679593439*^9}, {
   3.755284835801292*^9, 3.755284869600712*^9}, {3.755286503686242*^9, 
   3.755286507790449*^9}, 3.7552867771878843`*^9, {3.755286824115098*^9, 
   3.7552868246938257`*^9}},ExpressionUUID->"d83d7194-7612-45a2-86c1-\
c7f43faabe57"]
}, Open  ]],

