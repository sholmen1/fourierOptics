+ihZKPD3taMZo1cTiP5S+EhSCEgfe+CmBKIlvvcekAbSVk7TwLTbzyPnZYE0
n/gFML3JxzNUDkhPU+ANB9EuMba1E4B0z50pdSDa78/xJhB9S+sSmI7z2aQ2
E0iXC53QBdGVpdc5rwDplGV3wfSk/rTfL4H015MNYBoATsXb4g==
  
  "],ExpressionUUID->"7ca191a5-36fb-4a6c-af05-91966d879bb8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Numerical Fourier transform in 3 ways", "Section",
 CellChangeTimes->{{3.755274445590074*^9, 3.7552744559729652`*^9}, {
  3.756557368938217*^9, 3.756557373555656*^9}, {3.756560675677437*^9, 
  3.756560675919579*^9}, {3.7565881223895206`*^9, 
  3.756588125727878*^9}},ExpressionUUID->"0cad919b-8e27-44ac-95ec-\
f2af5ed95fbb"],

Cell[TextData[StyleBox["1.1 Summation form of the numerical Fourier transform \
(AKA nonuniform discrete Fourier transform)",
 FontWeight->"Bold"]], "Text",
 FontSize->14,
 FontWeight->"Regular",ExpressionUUID->"1b5d248e-5661-45c4-9ea7-f6040637117c"],

Cell[TextData[{
 "Generally speaking, the Fourier transform can be calculated ",
 StyleBox["at any ",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox["POINT",
  FontWeight->"Bold",
  FontSlant->"Italic",
  FontVariations->{"Underline"->True},
  FontColor->RGBColor[0., 0., 0.]],
 StyleBox[" in Fourier space",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 ". The goal of this simple exercise is to write your own discretized, \
numerical Fourier transform using the following template:"
}], "Text",
 CellChangeTimes->{{3.756557377230928*^9, 3.756557446978877*^9}, {
  3.756557556914289*^9, 3.756557562958906*^9}, {3.756557729260766*^9, 
  3.75655773004984*^9}, {3.756560677467579*^9, 3.756560709503097*^9}, {
  3.756578002528997*^9, 3.756578003755828*^9}, {3.756580164561122*^9, 
  3.7565801932036743`*^9}, {3.756583810777207*^9, 3.7565838229401703`*^9}, {
  3.756920752080741*^9, 3.756920752975209*^9}, {3.7570027461153717`*^9, 
  3.757002746571204*^9}},ExpressionUUID->"f7632aaf-e1d5-406d-9b86-\
30f5f08502c1"],

Cell[TextData[{
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["F", "~"], "(", 
     SubscriptBox["f", "x"], ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"n", "=", "1"}], "N"], 
     RowBox[{"f", "(", "n", ")"}], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", 
       SubscriptBox["f", "x"], "n", " ", "\[CapitalDelta]x"}]], 
     "\[CapitalDelta]x"}]}], TraditionalForm]],ExpressionUUID->
  "ab828b02-be1f-457d-9dcf-b1de6e8fdcd2"],
 "\n\nBecause this form allows you to calculate the Fourier transform in \
reciprocal space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ForAll]", 
    RowBox[{
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox["f", "x"], "\[RightBracketingBar]"}], "\[LessEqual]", 
     FractionBox["1", 
      RowBox[{"2", "\[CapitalDelta]x"}]]}]}], TraditionalForm]],
  ExpressionUUID->"b63e5e6a-da83-4e7f-b8d9-44abf78eb20a"],
 ", your program must include variables that control:\n\n\t\t1) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[DifferentialD]", 
    SubscriptBox["f", "x"]}], TraditionalForm]],ExpressionUUID->
  "cc39d1ab-3ed7-4db4-843d-b9da576d5b49"],
 "\tand\n\t\t2) ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["f", 
    RowBox[{"x", "\[InvisibleComma]", "Max"}]], TraditionalForm]],
  ExpressionUUID->"1a095cac-1cc0-4ae4-9bd4-35c0d4f9448b"],
 "\n\n\t\tleaving the number of pixels to be calculated as\n\n\t\t3) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{
     SubscriptBox["f", 
      RowBox[{"x", "\[InvisibleComma]", "Max"}]], "/", 
     RowBox[{"\[DifferentialD]", 
      SubscriptBox["f", "x"]}]}]}], TraditionalForm]],ExpressionUUID->
  "77f5169a-c807-4c70-8f6e-67fe060f7372"],
 ",\twhere it is not necessary that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", "N"}], TraditionalForm]],ExpressionUUID->
  "00ad0c7c-3c9b-42ef-b3ce-f0ad78ebcf50"],
 ".\n\n\t\t",
 StyleBox["REMEMBER",
  FontWeight->"Bold"],
 StyleBox[":",
  FontWeight->"Plain"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", ",", 
    RowBox[{"N", " ", "\[Element]", " ", "\[DoubleStruckCapitalZ]"}]}], 
   TraditionalForm]],ExpressionUUID->"5a979801-c9af-404e-9f08-f44afdc3ec30"],
 " so you must take steps to ensure grid consistency in the case that  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["f", 
      RowBox[{"x", "\[InvisibleComma]", "Max"}]], "/", 
     RowBox[{"\[DifferentialD]", 
      SubscriptBox["f", "x"]}]}], "\[NotElement]", 
    "\[DoubleStruckCapitalZ]"}], TraditionalForm]],ExpressionUUID->
  "95d2185b-a93a-4e31-ae1b-2366c62c73ef"],
 ".\n\nYour program must also include a variable that allows you to shift the \
frequency axis i.e., ",
 Cell[BoxData[
  SubscriptBox["f", "0"]],ExpressionUUID->
  "1eb714ee-86f8-4b77-9d5b-ab40a3ca77f2"]
}], "Text",
 CellChangeTimes->{{3.7565577403301277`*^9, 3.756557740793241*^9}, {
   3.7565577834733963`*^9, 3.756557920583446*^9}, {3.756558212811173*^9, 
   3.75655822434894*^9}, {3.756560729099217*^9, 3.756560762644474*^9}, {
   3.756578007023871*^9, 3.756578064853065*^9}, {3.756579429574616*^9, 
   3.756579434298403*^9}, {3.756579520293509*^9, 3.7565795361357403`*^9}, {
   3.756579577496231*^9, 3.75657974896243*^9}, {3.7565802200711813`*^9, 
   3.756580285784186*^9}, {3.7565803268278093`*^9, 3.756580329328216*^9}, {
   3.756582283953608*^9, 3.756582328189015*^9}, {3.7565832364525223`*^9, 
   3.756583262653726*^9}, {3.756583832994355*^9, 3.75658389434623*^9}, {
   3.756583928301347*^9, 3.756583930827458*^9}, {3.7565839717642307`*^9, 
   3.756583975298934*^9}, {3.75658410705167*^9, 3.7565841099048567`*^9}, {
   3.7565841542212687`*^9, 3.7565841546032543`*^9}, {3.756585386698941*^9, 
   3.756585387834152*^9}, 3.756845397503124*^9, 3.756912711603101*^9, {
   3.756913793933691*^9, 3.75691380764991*^9}, {3.756920479880579*^9, 
   3.756920487999215*^9}, {3.756957791602179*^9, 3.7569577960770597`*^9}},
 FontWeight->"Regular",ExpressionUUID->"0f6f902a-6ab0-4203-8536-5ddddf9dac11"],

Cell[TextData[{
 StyleBox["Demonstrate:\n",
  FontSize->14,
  FontWeight->"Bold"],
 "\nPlot the numerical Fourier transform of a finitely supported function and \
the original function (separate axes). The plots of the function and its \
Fourier transform must include both the real and imaginary parts of both \
functions. Include at least one plot clearly demonstrating the ability of \
your program to calculate the Fourier transform ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ForAll]", 
    RowBox[{
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox["f", "x"], "\[RightBracketingBar]"}], "\[LessEqual]", 
     RowBox[{
      RowBox[{"1", "/", "2"}], "\[CapitalDelta]x"}]}]}], TraditionalForm]],
  ExpressionUUID->"d7bf287a-9b5b-403f-906d-ac639d8159db"],
 " in reciprocal space. The Fourier transform must be calculated on a \
\[OpenCurlyQuote]zoomed\[CloseCurlyQuote] shifted grid. An example is shown \
below:"
}], "Text",
 CellChangeTimes->{{3.75658067961449*^9, 3.756580690928288*^9}, {
  3.756580741060608*^9, 3.756580753769359*^9}, {3.7565824304499893`*^9, 
  3.7565824656411667`*^9}, {3.75658328247931*^9, 3.756583336243183*^9}, {
  3.7565842341078863`*^9, 3.756584239600428*^9}, {3.756584442270997*^9, 
  3.756584446679553*^9}, {3.756913826738297*^9, 3.756913833687311*^9}, {
  3.756918057532921*^9, 3.756918058799039*^9}, {3.7569578412932997`*^9, 
  3.75695786377619*^9}, {3.7569579451215067`*^9, 3.756957947097073*^9}},
 FontWeight->"Regular",
 Background->RGBColor[
  0.87, 0.94, 1],ExpressionUUID->"fe5a6827-6b28-4731-82c9-d8973b5eea2c"],

