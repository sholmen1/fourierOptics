Cell[TextData[{
 "PHGN 570: Computational Project 3\n",
 StyleBox["Propagation and Optical Fourier Transforms",
  FontSize->24,
  FontWeight->"Regular"]
}], "Chapter",
 CellChangeTimes->{{3.7552740620598*^9, 3.755274072243856*^9}, {
