Cell[TextData[StyleBox["2. 4-f spatial filter for optical image processing",
 FontSize->18,
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.760663736325069*^9, 3.760663736439744*^9}},
 FontSize->13,
 FontWeight->"Regular",ExpressionUUID->"b7bf21b9-0977-4567-961e-9fbfd7a84cc3"],

Cell[TextData[{
 "Construct a 4-f imaging system. This system will be used in two separate \
efforts so as usual, write well commented and well organized code. The system \
