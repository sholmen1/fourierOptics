Cell[TextData[StyleBox["1.1 Verify Gaussian beam parameters",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.76063845290236*^9, 3.7606384588721457`*^9}, {
  3.7606384926578608`*^9, 3.760638504807088*^9}, {3.7606412761792727`*^9, 
  3.760641281290709*^9}, {3.760642824870195*^9, 3.7606428256086187`*^9}, {
  3.760656070378839*^9, 3.7606560818220873`*^9}},
 FontSize->14,
 FontWeight->"Regular",ExpressionUUID->"2948d297-000d-410e-8c2c-4b638e658930"],

Cell[TextData[{
 StyleBox["Introduction: ",
  FontWeight->"Bold"],
 "One of the first tasks when numerically propagating fields is to confirm \
your code is correct by comparing to a known, analytical solution. One such \
example is the confirmation of Gaussian beam parameters.\n",
 StyleBox["\nInstructions:",
  FontWeight->"Bold"],
 " ",
 StyleBox["Make an isotropic, 2D grid of points with N = 64 pixels, pixel \
size of \[DifferentialD]x=1\[Mu]m, and \[Lambda] = 4 \[Mu]m. The Gaussian \
beam radius will be 10\[Mu]m, and your propagation will have a step size in \
the z-direction of \[Lambda]/20 in order to sample the wave finely. The \
propagation distance will be zR i.e., the Rayleigh range.  ",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 "Your program should display the physical extent of the simulation grid to \
the command window for reference."
}], "Text",
 CellChangeTimes->{{3.760656117934648*^9, 3.7606561631066027`*^9}, {
   3.760656207399218*^9, 3.760656228260765*^9}, {3.760657765353059*^9, 
   3.760657769060817*^9}, {3.7606578031006517`*^9, 3.7606578899590807`*^9}, {
   3.760657922238779*^9, 3.7606580180546713`*^9}, {3.760658149313569*^9, 
   3.76065816294737*^9}, 3.760662503108934*^9, {3.760662670680552*^9, 
   3.760662674641078*^9}, {3.7606638237331867`*^9, 3.760663825768929*^9}, {
   3.760664156748846*^9, 3.760664157018605*^9}, {3.760664227955636*^9, 
   3.7606642326969347`*^9}},ExpressionUUID->"ef01801d-0ba8-42aa-9102-\
0ac2ad77dab2"],

