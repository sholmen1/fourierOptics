Cell[TextData[StyleBox["1. Propagation mayhem",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.760640048666945*^9, 3.760640055050974*^9}},
 FontSize->18,
 FontWeight->"Regular",ExpressionUUID->"5e427473-4b31-4654-a902-82121b22f415"],

Cell[TextData[{
 "This project will rely heavily on your working knowledge of Gaussian beam \
mechanics. You should have recently (in the homework) calculated the Fresnel \
propagation of a Gaussian transverse profile. In that work you showed that \
Gaussian beam parameters include:\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"w", "(", "z", ")"}], " ", "=", " ", 
    RowBox[{
     SubscriptBox["w", "0"], 
     SqrtBox[
      RowBox[{"1", "+", 
       RowBox[{
        SuperscriptBox["z", "2"], "/", 
        SubsuperscriptBox["z", "R", "2"]}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"bff0e1f9-0568-46e2-bfd8-d95dfad7d042"],
 ",\tThe beam radius as a function of z\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "z", ")"}], " ", "=", " ", 
    RowBox[{"z", " ", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{
        SubsuperscriptBox["z", "R", "2"], "/", 
        SuperscriptBox["z", "2"]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"52d22e48-4190-4591-b345-a3aae4a82494"],
 ",\t\tThe wavefront curvature radius as a function of z\n\t\n\tand\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Psi]", "(", "z", ")"}], " ", "=", 
    RowBox[{"arctan", "(", 
     RowBox[{"z", "/", 
      SubscriptBox["z", "R"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "0547b6ea-9b9b-458c-8c3a-f257eb2e2753"],
 "\t\tThe Gouy phase as a function of z\n\t\n\tand where the Rayleigh range \
is defined as\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["z", "R"], "=", 
    FractionBox[
     RowBox[{"\[Pi]", " ", 
      SubsuperscriptBox["w", "0", "2"]}], "\[Lambda]"]}], TraditionalForm]],
  ExpressionUUID->"75c7c38c-9efc-4152-84cc-bb4b73a788df"],
 ",\n\t\n\tand the minimum spot size is given by\n\t\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "0"], TraditionalForm]],ExpressionUUID->
  "514ce7dc-3c1d-45b7-94e7-7e2051ad23dd"],
 "\n\t\nAs an aside, note that depending on the definition constants, the \
Fresnel number that we defined in class is simply the Rayleigh range divided \
by z i.e.,\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"F", "\[Congruent]", 
     FractionBox[
      SubscriptBox["z", "R"], "z"]}], "=", 
    FractionBox[
     RowBox[{"\[Pi]", " ", 
      SubsuperscriptBox["w", "0", "2"]}], 
     RowBox[{"z", " ", "\[Lambda]"}]]}], TraditionalForm]],ExpressionUUID->
  "7097da66-3ef1-4e15-aaf1-23228783aa2a"],
 "\n\nAn illustration of Gaussian beam parameters is shown below:\n\t\n\t\t\t\
\t\t\t\t\t",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
