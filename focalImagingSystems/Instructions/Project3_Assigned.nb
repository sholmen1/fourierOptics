Cell[TextData[{
 StyleBox["Deliverable: ",
  FontSize->13,
  FontWeight->"Bold"],
 StyleBox["Vary the width of the phase filter in Fourier space and find an \
optimal width that transfers the phase information in the object to amplitude \
information in the image most efficiently. Provide a plot like the one above.\
\n\n1) What width seems to work the best?\n2) What purpose could this sort of \
process serve?",
  FontSize->13]
}], "Text",
 CellChangeTimes->{{3.760653317870872*^9, 3.760653379482809*^9}, {
